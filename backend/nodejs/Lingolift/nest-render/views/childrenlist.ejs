<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <title>LingoLift投影端 - 儿童信息</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    /* 页面背景 */
    body {
      background: linear-gradient(135deg, #74ABE2, #5563DE);
      min-height: 100vh;
      margin: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    /* 容器 */
    .container {
      background: #fff;
      border-radius: 1rem;
      padding: 20px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      max-width: 600px;
      width: 100%;
    }
    /* 标题 */
    h2 {
      text-align: center;
      font-weight: bold;
      margin-bottom: 20px;
    }
    /* 超链接包裹整个儿童卡片 */
    .child-card-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    /* 儿童卡片 */
    .child-card {
      display: flex;
      align-items: center;
      padding: 15px;
      border-bottom: 1px solid #ddd;
      background: white;
      transition: background 0.3s ease-in-out;
      animation: fadeInUp 0.6s ease;
    }
    /* 鼠标悬停高亮 */
    .child-card:hover {
      background: #f0f0f0;
    }
    /* 淡入上移动画 */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    /* 头像 */
    .child-image {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 50%;
      border: 3px solid #5563DE;
    }
    /* 儿童信息 */
    .child-info {
      flex: 1;
      margin-left: 15px;
    }
    .child-info p {
      margin: 5px 0;
      font-size: 14px;
    }
    /* 返回按钮 */
    .back-btn {
      display: block;
      width: 100%;
      text-align: center;
      margin-top: 20px;
    }
    /* Footer 样式 */
    footer {
      margin-top: 20px;
      color: #fff;
      font-size: 0.9rem;
      text-align: center;
      width: 100%;
    }
    footer a {
      color: #fff;
      text-decoration: none;
    }
    footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>儿童信息列表</h2>

    <% if (error) { %>
      <div class="alert alert-danger text-center"><%= error %></div>
    <% } %>

    <% if (children && children.length > 0) { %>
      <% children.forEach(child => { %>
        <!-- 用超链接包裹整个卡片 -->
        <a href="/teacher/child/<%= child?._id %>?name=<%= encodeURIComponent(child?.name) %>" class="child-card-link">
          <div class="child-card">
            <!-- 头像 -->
            <img src="<%= child?.childImage || 'https://via.placeholder.com/80' %>" 
                 class="child-image" referrerpolicy="no-referrer" alt="儿童头像">
            <div class="child-info">
              <p><strong>姓名：</strong> <%= child?.name || '未知' %></p>
              <p><strong>年龄：</strong> <%= child?.age || '未知' %></p>
              <p><strong>性别：</strong> <%= child?.gender === 'male' ? '男' : '女' %></p>
              <p><strong>信息创建时间：</strong> 
                <%= new Date(child?.createdAt).toLocaleString("zh-CN", { 
                  timeZone: "Asia/Shanghai", 
                  year: "numeric", 
                  month: "2-digit", 
                  day: "2-digit", 
                  hour: "2-digit", 
                  minute: "2-digit", 
                  hour12: true 
                }) || '无数据' %>
              </p>
              <p><strong>上次授课时间：</strong> 
                <%= new Date(child?.changedAt).toLocaleString("zh-CN", { 
                  timeZone: "Asia/Shanghai", 
                  year: "numeric", 
                  month: "2-digit", 
                  day: "2-digit", 
                  hour: "2-digit", 
                  minute: "2-digit", 
                  hour12: true 
                }) || '无数据' %>
              </p>
            </div>
          </div>
        </a>
      <% }) %>
    <% } else { %>
      <div class="alert alert-info text-center">暂无儿童信息</div>
    <% } %>

    <a href="/teacher/dashboard" class="btn btn-secondary back-btn">返回菜单</a>
  </div>

  <footer>
    <p>
      © HKUST(GZ), ARK Lab, 2025<br>
      <a href="https://arkxlab.github.io" target="_blank">访问 ARK Lab 官网</a>
    </p>
  </footer>
</body>
</html>
