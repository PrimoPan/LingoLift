<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LingoLift投影端 - 教师后台</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    /* 背景渐变与居中 */
    body {
      background: linear-gradient(135deg, #74ABE2, #5563DE);
      height: 100vh;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
    }
    /* 卡片样式及动态效果 */
    .card {
      border: none;
      border-radius: 1rem;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      width: 360px;
      margin-bottom: 20px;
      animation: slideInFade 0.8s ease-out;
    }
    /* 滑入渐变动画 */
    @keyframes slideInFade {
      0% {
        opacity: 0;
        transform: translateY(-20px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }
    /* 按钮样式 */
    .btn-primary {
      background-color: #5563DE;
      border: none;
      transition: background-color 0.3s ease;
    }
    .btn-primary:hover {
      background-color: #4454b5;
    }
    .btn-secondary {
      background-color: #6c757d;
      border: none;
      transition: background-color 0.3s ease;
    }
    .btn-secondary:hover {
      background-color: #5a6268;
    }
    /* Footer 样式 */
    footer {
      margin-top: 20px;
      color: #fff;
      font-size: 0.9rem;
      text-align: center;
    }
    footer a {
      color: #fff;
      text-decoration: none;
    }
    footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="card p-4">
    <h2 class="text-center mb-4">欢迎, <%= username %>!</h2>
    <div class="d-flex justify-content-center gap-3 mb-3">
      <!-- 去上课按钮跳转到 /teacher/childrenlist -->
      <a href="/teacher/childrenlist" class="btn btn-primary w-100">去上课 (AR)</a>
      <a href="#" class="btn btn-secondary w-100">打印教案</a>
    </div>
    <div class="text-center">
      <a href="/teacher/logout" class="btn btn-danger w-100">退出登录</a>
    </div>
  </div>
  <footer>
    <p>
      © HKUST(GZ), ARK Lab, 2025<br>
      <a href="https://arkxlab.github.io/" target="_blank">访问 ARK Lab 官网</a>
    </p>
  </footer>
</body>
</html>
